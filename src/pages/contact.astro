---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ui/ContactForm.jsx";
import SocialLinks3D from "../components/ui/SocialLinks3D.jsx";
---

<Layout
  title="Contact | Adnan Rohmat Kurniansah"
  description="Get in touch with Adnan Rohmat Kurniansah for projects, collaborations, or just a conversation."
  sideBarActiveItemID="contact"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-16 md:py-32 flex flex-col gap-16">
    <div>
      <div class="eyebrow mb-4">Get in Touch</div>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <h1 class="section-heading text-[var(--text-primary)]">
          Let's build something<br />
          <span class="gradient-text">together.</span>
        </h1>
        <p class="text-sm text-[var(--text-primary)]/55 max-w-sm leading-relaxed md:text-right">
          Open to freelance work, collaborations, or a quick conversation about tech and ideas.
        </p>
      </div>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-20 items-start">
      <div class="flex flex-col gap-8">
          <div class="flex flex-col gap-3">
          <a
            href="mailto:atnandimas@gmail.com"
            class="interactive card-base p-5 flex items-center gap-4 group"
          >
            <div class="w-11 h-11 rounded-xl bg-[var(--accent)]/10 border border-[var(--accent)]/20 flex items-center justify-center flex-shrink-0 transition-colors duration-200 group-hover:bg-[var(--accent)]/20">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[var(--accent)]" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div class="flex flex-col gap-0.5 min-w-0">
              <span class="text-xs font-mono-technical text-[var(--text-primary)]/40 uppercase tracking-wider">Email</span>
              <span class="text-base font-medium text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors truncate">atnandimas@gmail.com</span>
            </div>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto flex-shrink-0 text-[var(--text-primary)]/20 group-hover:text-[var(--accent)] group-hover:translate-x-0.5 transition-all duration-200" aria-hidden="true">
              <path d="M1 7h12M7 1l6 6-6 6"/>
            </svg>
          </a>

          <a
            href="https://www.linkedin.com/in/adnan-rohmat-kurniansah-41576827a/"
            target="_blank"
            rel="noopener noreferrer"
            class="interactive card-base p-5 flex items-center gap-4 group"
          >
            <div class="w-11 h-11 rounded-xl bg-[var(--accent-alt)]/10 border border-[var(--accent-alt)]/20 flex items-center justify-center flex-shrink-0 transition-colors duration-200 group-hover:bg-[var(--accent-alt)]/20">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-[var(--accent-alt)]" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <div class="flex flex-col gap-0.5 min-w-0">
              <span class="text-xs font-mono-technical text-[var(--text-primary)]/40 uppercase tracking-wider">LinkedIn</span>
              <span class="text-base font-medium text-[var(--text-primary)] group-hover:text-[var(--accent-alt)] transition-colors truncate">Adnan Rohmat Kurniansah</span>
            </div>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto flex-shrink-0 text-[var(--text-primary)]/20 group-hover:text-[var(--accent-alt)] group-hover:translate-x-0.5 transition-all duration-200" aria-hidden="true">
              <path d="M1 7h12M7 1l6 6-6 6"/>
            </svg>
          </a>

          <a
            href="https://github.com/AdnanRohmatKurniansah"
            target="_blank"
            rel="noopener noreferrer"
            class="interactive card-base p-5 flex items-center gap-4 group"
          >
            <div class="w-11 h-11 rounded-xl bg-[var(--border)] flex items-center justify-center flex-shrink-0 transition-colors duration-200 group-hover:bg-[var(--text-primary)]/10">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-[var(--text-primary)]/65" aria-hidden="true">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
            </div>
            <div class="flex flex-col gap-0.5 min-w-0">
              <span class="text-xs font-mono-technical text-[var(--text-primary)]/40 uppercase tracking-wider">GitHub</span>
              <span class="text-base font-medium text-[var(--text-primary)] group-hover:text-[var(--text-primary)] transition-colors truncate">AdnanRohmatKurniansah</span>
            </div>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto flex-shrink-0 text-[var(--text-primary)]/20 group-hover:text-[var(--text-primary)]/55 group-hover:translate-x-0.5 transition-all duration-200" aria-hidden="true">
              <path d="M1 7h12M7 1l6 6-6 6"/>
            </svg>
          </a>
        </div>
        <div class="flex flex-col gap-4">
          <p class="text-sm font-mono-technical text-[var(--text-primary)]/35 uppercase tracking-widest">Social platforms</p>
          <SocialLinks3D client:visible />
        </div>
        <div class="p-5 rounded-2xl border border-emerald-500/20 bg-emerald-500/5">
          <div class="flex items-start gap-3">
            <span class="availability-dot flex-shrink-0 mt-1 w-2 h-2 rounded-full bg-emerald-400"></span>
            <div class="flex flex-col gap-1.5">
              <p class="text-base font-semibold text-emerald-400">Currently available</p>
              <p class="text-sm text-[var(--text-primary)]/55 leading-relaxed">
                Open to freelance projects, internship opportunities, and collaborative work. Typical response within 24 hours.
              </p>
            </div>
          </div>
        </div>
      </div>
      <div>
        <ContactForm client:visible />
      </div>
    </div>
  </div>
</Layout>
