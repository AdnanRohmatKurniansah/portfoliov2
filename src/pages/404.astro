---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Page Not Found">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 pt-40 pb-32 flex flex-col items-center text-center gap-8 min-h-[70vh] justify-center">
    <div class="eyebrow">Error 404</div>
    <div class="flex flex-col gap-4">
      <h1 class="text-[clamp(5rem,18vw,7rem)] font-extrabold leading-none tracking-tight font-mono-technical gradient-text select-none">
        404
      </h1>
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--text-primary)]">
        Page not found
      </h2>
      <p class="text-sm md:text-base text-[var(--text-primary)]/50 max-w-md leading-relaxed font-mono-technical">
        // The path you requested doesn't exist in this architecture.
      </p>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-3 mt-2">
      <a
        href="/"
        class="interactive inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-semibold bg-[var(--text-primary)] text-[var(--bg-primary)] hover:bg-[var(--text-primary)]/90 transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0"
      >
        Back to home
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M1 7h12M7 1l6 6-6 6"/>
        </svg>
      </a>
      <a
        href="/projects"
        class="interactive inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-medium border border-[var(--border)] text-[var(--text-primary)]/70 hover:text-[var(--text-primary)] hover:border-[var(--text-primary)]/30 hover:bg-[var(--border)] transition-all duration-200"
      >
        View projects
      </a>
    </div>
  </div>
</Layout>
