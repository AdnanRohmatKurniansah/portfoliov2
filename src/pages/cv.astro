---
import Layout from "../layouts/Layout.astro";
import Timeline from "../components/ui/Timeline.jsx";

const certifications = [
  {
    title: "Belajar Dasar Pemrograman JavaScript",
    link: "https://www.dicoding.com/certificates/JMZV1N0WQXN9"
  },
  {
    title: "Belajar Membuat Aplikasi Web dengan React",
    link: "https://www.dicoding.com/certificates/JMZV19V0QXN9"
  },
  {
    title: "Belajar Membuat Front-End Web untuk Pemula",
    link: "https://www.dicoding.com/certificates/GRX5298Y2X0M"
  }
];

const skills = [
  'JavaScript',
  'TypeScript',
  'React',
  'Next.js',
  'Tailwind CSS',
  'PHP',
  'Laravel',
  'Node.js',
  'Express.js',
  'NestJS',
  'MySQL',
  'PostgreSQL',
  'MongoDB',
  'Supabase',
  'Prisma',
  'Git',
];
---

<Layout
  title="Resume | Adnan Rohmat Kurniansah"
  description="CV and resume of Adnan Rohmat Kurniansah — Fullstack Developer."
  sideBarActiveItemID="cv"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-16 md:py-32 flex flex-col gap-16">
    <div>
      <div class="eyebrow mb-4">Resume</div>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <h1 class="section-heading text-[var(--text-primary)]">
          Curriculum <span class="gradient-text">Vitae</span>
        </h1>
      </div>
    </div>

    <div class="card-base p-7 md:p-8 flex flex-col md:flex-row gap-6 items-start">
      <div class="w-16 h-16 rounded-2xl overflow-hidden border border-[var(--border)] flex-shrink-0">
        <img src="/profile.jpeg" alt="Adnan Rohmat Kurniansah" class="w-full h-full object-cover object-top" loading="lazy" />
      </div>
      <div class="flex flex-col gap-2">
        <div class="flex flex-col gap-0.5">
          <h2 class="text-lg font-bold text-[var(--text-primary)]">Adnan Rohmat Kurniansah</h2>
          <p class="text-sm font-mono-technical text-[var(--accent)]">Fullstack Developer / Software Engineer</p>
        </div>
        <p class="text-sm text-[var(--text-primary)]/65 leading-relaxed max-w-2xl">
          Software engineer with expertise in web development, comfortable across the full stack. 
          I'm a creative problem solver focused on building intuitive, user-friendly products 
          that enhance user experience and deliver real value.
        </p>
        <div class="flex flex-wrap items-center gap-4 mt-1 text-xs text-[var(--text-primary)]/45 font-mono-technical">
          <span class="flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Yogyakarta, Indonesia
          </span>
          <span class="flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            atnandimas@gmail.com
          </span>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-6">
      <h2 class="text-base font-semibold text-[var(--text-primary)]">Experience & Education</h2>
      <Timeline client:load />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="card-base p-7">
        <h2 class="text-base font-semibold text-[var(--text-primary)] mb-6">Certifications</h2>
        <ul class="flex flex-col gap-0">
          {certifications.map((cert, i) => (
            <li class={`py-4 ${i < certifications.length - 1 ? 'border-b border-[var(--border)]' : ''}`}>
              <a
                href={cert.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-start justify-between gap-3 text-sm text-[var(--text-primary)]/70 hover:text-[var(--text-primary)] transition-colors duration-200"
              >
                <div class="flex items-start gap-2.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-[var(--accent)] flex-shrink-0 mt-1.5"></span>
                  <span class="leading-relaxed">{cert.title}</span>
                </div>
                <svg width="12" height="12" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" class="flex-shrink-0 mt-0.5 opacity-30 group-hover:opacity-70 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 transition-all" aria-hidden="true">
                  <path d="M1 9L9 1M9 1H3M9 1v6"/>
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="card-base p-7">
        <h2 class="text-base font-semibold text-[var(--text-primary)] mb-6">Skills</h2>
        <div class="flex flex-wrap gap-2">
          {skills.map((skill) => (
            <span class="text-xs font-mono-technical px-3 py-1.5 rounded-lg border border-[var(--border)] text-[var(--text-primary)]/60 bg-[var(--border)]/20 hover:border-[var(--accent)]/40 hover:text-[var(--accent)] transition-all duration-200">
              {skill}
            </span>
          ))}
        </div>
      </div>

    </div>

  </div>
</Layout>
