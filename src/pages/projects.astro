---
import Layout from "../layouts/Layout.astro";
import ProjectsGrid from "../components/ui/ProjectsGrid.jsx";
---

<Layout
  title="Projects | Adnan Rohmat Kurniansah"
  description="Fullstack web applications, platforms, and tools built by Adnan Rohmat Kurniansah."
  sideBarActiveItemID="projects"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-16 md:py-32">

    <div class="mb-16 md:mb-20">
      <div class="eyebrow mb-4">All Work</div>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <h1 class="section-heading text-[var(--text-primary)] max-w-xl">
          Everything I've<br />
          <span class="gradient-text">built and shipped.</span>
        </h1>
        <p class="text-sm text-[var(--text-primary)]/55 max-w-sm leading-relaxed md:text-right">
          A collection of real projects — client work, open-source tools, and personal builds.
        </p>
      </div>
    </div>

    <ProjectsGrid client:load limit={100}/>

    <div class="mt-16 pt-10 border-t border-[var(--border)] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-[var(--text-primary)]/50 font-mono-technical">
        // More repositories and experiments on GitHub
      </p>
      <a
        href="https://github.com/AdnanRohmatKurniansah"
        target="_blank"
        rel="noopener noreferrer"
        class="interactive inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-[var(--border)] text-sm font-medium text-[var(--text-primary)]/70 hover:text-[var(--text-primary)] hover:border-[var(--text-primary)]/30 hover:bg-[var(--border)] transition-all duration-200"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        View GitHub profile
      </a>
    </div>

  </div>
</Layout>
