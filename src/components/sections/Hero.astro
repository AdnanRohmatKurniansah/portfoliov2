---
import HeroScene from '../3d/HeroScene.jsx';
import ParticleField from '../3d/ParticleField.jsx';
import TypewriterTagline from '../ui/TypewriterTagline.jsx';

const techStack = [
  'PHP', 'Laravel', 'CodeIgniter', 'JavaScript', 'TypeScript',
  'React', 'Next.js', 'Node.js', 'Express.js',
  'MySQL', 'PostgreSQL', 'MongoDB', 'Tailwind CSS', 'Bootstrap',
  'PHP', 'Laravel', 'CodeIgniter', 'JavaScript', 'TypeScript',
  'React', 'Next.js', 'Node.js', 'Express.js',
  'MySQL', 'PostgreSQL', 'MongoDB', 'Tailwind CSS', 'Bootstrap',
];
---

<section id="home-hero" class="relative min-h-screen flex flex-col justify-center overflow-hidden h-[72px] md:h-[80px] pb-0">
  <HeroScene client:load />
  <ParticleField client:load />

  <div class="deco-corner-tl" aria-hidden="true"></div>
  <div class="deco-corner-tr" aria-hidden="true"></div>
  <div class="deco-corner-bl" aria-hidden="true"></div>
  <div class="deco-corner-br" aria-hidden="true"></div>

  <div class="absolute -top-20 -right-20 pointer-events-none hidden lg:block" aria-hidden="true">
    <div class="deco-ring" style="width:320px;height:320px;animation-duration:45s;opacity:0.08;"></div>
  </div>
  <div class="absolute -top-8 -right-8 pointer-events-none hidden lg:block" aria-hidden="true">
    <div class="deco-ring-rev" style="width:200px;height:200px;animation-duration:30s;opacity:0.07;"></div>
  </div>
  <div class="absolute -bottom-16 -left-16 pointer-events-none hidden lg:block" aria-hidden="true">
    <div class="deco-ring" style="width:220px;height:220px;animation-duration:38s;opacity:0.06;"></div>
  </div>
  <div class="deco-pulse-dot hidden lg:block" style="width:3px;height:3px;top:32%;left:3%;" aria-hidden="true"></div>
  <div class="deco-pulse-dot hidden lg:block" style="width:4px;height:4px;top:62%;right:3%;background:var(--accent-alt);animation-delay:1.2s;" aria-hidden="true"></div>

  <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-[var(--accent)]/5 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-1/3 left-1/5 w-72 h-72 bg-[var(--accent-alt)]/5 rounded-full blur-[100px] pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16 items-center min-h-[75vh]">

      <div class="flex flex-col col-span-3 gap-6 lg:gap-8 min-w-0">
        <div class="flex items-center gap-2.5 w-fit">
          <div class="flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-emerald-500/25 bg-emerald-500/8">
            <span class="availability-dot w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"></span>
            <span class="text-xs font-medium text-emerald-400 tracking-wide">Available for projects</span>
          </div>
        </div>

        <div class="flex flex-col gap-4 min-w-0 w-full">
          <TypewriterTagline client:load />
          <p class="text-base md:text-lg text-[var(--text-primary)]/60 max-w-lg leading-relaxed">
            Fullstack developer with experience building web applications end-to-end.
            Comfortable on both frontend and backend — from crafting UIs to designing APIs and databases.
          </p>
        </div>

        <div class="flex flex-wrap items-center gap-3">
          <a
            href="https://www.linkedin.com/in/adnan-rohmat-kurniansah-41576827a/"
            target="_blank"
            rel="noopener noreferrer"
            class="interactive inline-flex items-center gap-2 px-4 md:px-7 py-3 md:py-4 rounded-xl text-sm font-semibold bg-[var(--text-primary)] text-[var(--bg-primary)] hover:opacity-90 transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)]/50"
          >
            Let's connect
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 7h12M7 1l6 6-6 6"/></svg>
          </a>
          <a
            href="/projects"
            class="interactive inline-flex items-center gap-2 px-4 md:px-7 py-3 md:py-4 rounded-xl text-sm font-medium border border-[var(--border)] text-[var(--text-primary)]/75 hover:text-[var(--text-primary)] hover:border-[var(--text-primary)]/25 hover:bg-[var(--border)] transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)]/50"
          >
            View my work
          </a>
        </div>

        <!-- <div class="flex items-center gap-5 sm:gap-8 pt-4 border-t border-[var(--border)]">
          <div class="flex flex-col gap-0.5">
            <span class="text-xl sm:text-2xl font-extrabold text-[var(--text-primary)] font-mono-technical">1+</span>
            <span class="text-[10px] sm:text-xs text-[var(--text-primary)]/45 uppercase tracking-wider whitespace-nowrap">Yrs exp</span>
          </div>
          <div class="w-px h-7 bg-[var(--border)]"></div>
          <div class="flex flex-col gap-0.5">
            <span class="text-xl sm:text-2xl font-extrabold text-[var(--text-primary)] font-mono-technical">8</span>
            <span class="text-[10px] sm:text-xs text-[var(--text-primary)]/45 uppercase tracking-wider whitespace-nowrap">Projects</span>
          </div>
          <div class="w-px h-7 bg-[var(--border)]"></div>
          <div class="flex flex-col gap-0.5">
            <span class="text-xl sm:text-2xl font-extrabold text-[var(--text-primary)] font-mono-technical">12+</span>
            <span class="text-[10px] sm:text-xs text-[var(--text-primary)]/45 uppercase tracking-wider whitespace-nowrap">Technologies</span>
          </div>
        </div> -->
      </div>

      <div class="hidden lg:flex col-span-2 items-center justify-end">
        <div class="relative w-full max-w-[420px]">
          <div
            class="absolute inset-0 rounded-2xl blur-3xl scale-95 pointer-events-none opacity-40"
            style="background: radial-gradient(ellipse at 60% 40%, rgba(6,182,212,0.18) 0%, rgba(168,85,247,0.12) 60%, transparent 100%);"
            aria-hidden="true"
          ></div>

          <div class="relative rounded-2xl border border-[var(--border)] bg-[var(--card)]/70 backdrop-blur-md overflow-hidden shadow-2xl">
            <div class="flex items-center gap-3 px-4 py-3 border-b border-[var(--border)] bg-[var(--bg-surface)]/50">
              <div class="flex items-center gap-1.5">
                <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
                <span class="w-3 h-3 rounded-full bg-amber-400/70"></span>
                <span class="w-3 h-3 rounded-full bg-emerald-500/70"></span>
              </div>
              <span class="text-[11px] font-mono-technical text-[var(--text-primary)]/35 tracking-wide">arksitec.dev — profile.ts</span>
            </div>

            <div class="p-5 font-mono-technical text-xs leading-6 overflow-x-auto">
              <div class="flex gap-4">
                <span class="text-[var(--text-primary)]/20 w-4 text-right flex-shrink-0 select-none">1</span>
                <span><span class="text-[var(--accent-alt)]">const</span><span class="text-[var(--text-primary)]"> developer </span><span class="text-[var(--text-primary)]/50">=</span><span class="text-[var(--accent)]"> &#123;</span></span>
              </div>
              <div class="flex gap-4">
                <span class="text-[var(--text-primary)]/20 w-4 text-right flex-shrink-0 select-none">2</span>
                <span class="pl-4"><span class="text-cyan-400">name</span><span class="text-[var(--text-primary)]/50">: </span><span class="text-emerald-400">"Adnan Rohmat K."</span><span class="text-[var(--text-primary)]/50">,</span></span>
              </div>
              <div class="flex gap-4">
                <span class="text-[var(--text-primary)]/20 w-4 text-right flex-shrink-0 select-none">3</span>
                <span class="pl-4"><span class="text-cyan-400">role</span><span class="text-[var(--text-primary)]/50">: </span><span class="text-emerald-400">"Fullstack Developer"</span><span class="text-[var(--text-primary)]/50">,</span></span>
              </div>
              <div class="flex gap-4">
                <span class="text-[var(--text-primary)]/20 w-4 text-right flex-shrink-0 select-none">4</span>
                <span class="pl-4"><span class="text-cyan-400">location</span><span class="text-[var(--text-primary)]/50">: </span><span class="text-emerald-400">"Yogyakarta, ID"</span><span class="text-[var(--text-primary)]/50">,</span></span>
              </div>
              <div class="flex gap-4">
                <span class="text-[var(--text-primary)]/20 w-4 text-right flex-shrink-0 select-none">5</span>
                <span class="pl-4"><span class="text-cyan-400">stack</span><span class="text-[var(--text-primary)]/50">: [</span></span>
              </div>
              {['"React", "Next.js", "Node.js",', '"PHP", "Laravel", "MySQL",', '"TypeScript", "Tailwind"'].map((line, i) => (
                <div class="flex gap-4">
                  <span class="text-[var(--text-primary)]/20 w-4 text-right flex-shrink-0 select-none">{6 + i}</span>
                  <span class="pl-8 text-amber-400">{line}</span>
                </div>
              ))}
              <div class="flex gap-4">
                <span class="text-[var(--text-primary)]/20 w-4 text-right flex-shrink-0 select-none">9</span>
                <span class="pl-4"><span class="text-[var(--text-primary)]/50">],</span></span>
              </div>
              <div class="flex gap-4">
                <span class="text-[var(--text-primary)]/20 w-4 text-right flex-shrink-0 select-none">10</span>
                <span class="pl-4"><span class="text-cyan-400">available</span><span class="text-[var(--text-primary)]/50">: </span><span class="text-[var(--accent-alt)]">true</span><span class="text-[var(--text-primary)]/50">,</span></span>
              </div>
              <div class="flex gap-4">
                <span class="text-[var(--text-primary)]/20 w-4 text-right flex-shrink-0 select-none">11</span>
                <span class="text-[var(--accent)]">&#125;</span><span class="text-[var(--text-primary)]/50">;</span>
              </div>
              <div class="flex gap-4 mt-1">
                <span class="text-[var(--text-primary)]/20 w-4 text-right flex-shrink-0 select-none">12</span>
                <span class="inline-block w-[7px] h-[14px] bg-[var(--accent)] rounded-sm" style="animation: blink-cursor 1.1s step-end infinite;" aria-hidden="true"></span>
              </div>
            </div>

            <div class="flex items-center justify-between px-4 py-2 border-t border-[var(--border)] bg-[var(--bg-surface)]/40">
              <div class="flex items-center gap-2">
                <span class="availability-dot w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                <span class="text-[10px] font-mono-technical text-emerald-400">open to work</span>
              </div>
              <span class="text-[10px] font-mono-technical text-[var(--text-primary)]/25">TypeScript · UTF-8</span>
            </div>
          </div>

          <div class="absolute -left-12 top-[18%] flex items-center gap-2 px-3 py-1.5 rounded-lg bg-[var(--card)] border border-[var(--border)] shadow-xl backdrop-blur-md" style="animation: float-badge 4s ease-in-out infinite;">
            <span class="w-2 h-2 rounded-full bg-cyan-400 flex-shrink-0"></span>
            <span class="text-xs font-mono-technical text-cyan-400">React</span>
          </div>
          <div class="absolute -right-10 top-[42%] flex items-center gap-2 px-3 py-1.5 rounded-lg bg-[var(--card)] border border-[var(--border)] shadow-xl backdrop-blur-md" style="animation: float-badge 4s ease-in-out infinite; animation-delay: 1.3s;">
            <span class="w-2 h-2 rounded-full bg-violet-400 flex-shrink-0"></span>
            <span class="text-xs font-mono-technical text-violet-400">Laravel</span>
          </div>
          <div class="absolute -left-8 bottom-[20%] flex items-center gap-2 px-3 py-1.5 rounded-lg bg-[var(--card)] border border-[var(--border)] shadow-xl backdrop-blur-md" style="animation: float-badge 4s ease-in-out infinite; animation-delay: 2.6s;">
            <span class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"></span>
            <span class="text-xs font-mono-technical text-emerald-400">Next.js</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="relative z-10 border-t border-[var(--border)] mt-10 lg:mt-12 py-3.5 overflow-hidden bg-[var(--bg-surface)]/30 backdrop-blur-sm">
    <div class="flex items-center gap-0 w-max marquee-track" aria-hidden="true">
      {techStack.map((tech) => (
        <span class="flex items-center gap-4 px-6 text-[11px] font-mono-technical text-[var(--text-primary)]/35 whitespace-nowrap">
          <span class="w-1 h-1 rounded-full bg-[var(--accent)]/40 flex-shrink-0"></span>
          {tech}
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes blink-cursor { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
  @keyframes float-badge { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-6px); } }
</style>
