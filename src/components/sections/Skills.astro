---
import SkillsBars from '../ui/SkillsBars.jsx';
---

<section id="skills" class="py-16 md:py-24 md:py-32 border-t border-[var(--border)] scroll-mt-20 relative overflow-hidden">
  <div class="deco-corner-tr hidden lg:block" aria-hidden="true"></div>
  <div class="deco-corner-bl hidden lg:block" aria-hidden="true"></div>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex flex-col gap-14 md:gap-28">
    <div>
      <div class="eyebrow mb-5">Skills & Experience</div>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">
        <h2 class="section-heading text-[var(--text-primary)] max-w-xl">
          What I know,<br />
          <span class="gradient-text">and where I've been.</span>
        </h2>
        <p class="text-base md:text-lg text-[var(--text-primary)]/55 max-w-sm leading-relaxed md:text-right">
          A practical skill set built through real projects, internships, and continuous learning.
        </p>
      </div>
    </div>

    <div class="flex flex-col gap-6">
      <h3 class="text-lg font-semibold text-[var(--text-primary)]">Technical proficiency</h3>
      <SkillsBars client:visible />
    </div>

  </div>
</section>
